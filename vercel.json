{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "yarn build",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 30,
      "excludeFiles": "{.git/**,.github/**,.husky/**,.vscode/**,.devcontainer/**,node_modules/**,.yarn/**,tests/**,scripts/**,bootstrap/ssr/**,resources/js/**,resources/css/**,storage/logs/**,storage/framework/cache/**,storage/framework/testing/**,storage/framework/sessions/**,storage/framework/views/**,public/build/**,**/*.md,docker-compose.yml,sail-init.sh}"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "/(favicon.ico|robots.txt|security.txt)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
